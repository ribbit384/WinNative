<?xml version="1.0" encoding="utf-8"?>
<!-- Card row for each installed or downloadable component shown on the Components screen. -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="10dp"
    android:background="@drawable/content_list_card_surface"
    android:orientation="vertical">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:minHeight="72dp"
        android:orientation="horizontal"
        android:paddingHorizontal="14dp"
        android:paddingVertical="12dp">

        <ImageView
            android:id="@+id/IVIcon"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:layout_marginEnd="14dp"
            android:background="@drawable/content_icon_surface"
            android:padding="10dp"
            app:tint="@color/settings_icon_tint" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_gravity="center_vertical"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/TVVersionName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:fontFamily="@font/inter"
                android:maxLines="1"
                android:textColor="@color/settings_text_primary"
                android:textSize="15sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/TVVersionCode"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:fontFamily="@font/inter"
                android:maxLines="1"
                android:textColor="@color/settings_text_secondary"
                android:textSize="12sp" />
        </LinearLayout>

        <ImageButton
            android:id="@+id/BTDownload"
            android:layout_width="34dp"
            android:layout_height="34dp"
            android:layout_marginStart="8dp"
            android:background="@drawable/content_action_button_background"
            android:padding="8dp"
            android:src="@drawable/ic_content_download"
            android:visibility="gone"
            app:tint="@color/settings_icon_tint" />

        <ProgressBar
            android:id="@+id/Progress"
            android:layout_width="22dp"
            android:layout_height="22dp"
            android:layout_marginStart="12dp"
            android:indeterminateTint="@color/settings_accent"
            android:visibility="gone" />

        <ImageButton
            android:id="@+id/BTMenu"
            android:layout_width="34dp"
            android:layout_height="34dp"
            android:layout_marginStart="8dp"
            android:background="@drawable/content_icon_surface"
            android:padding="8dp"
            android:scaleType="centerInside"
            android:src="@drawable/ic_content_chevron"
            app:tint="@color/settings_icon_tint" />
    </LinearLayout>
</LinearLayout>
