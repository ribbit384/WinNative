<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="10dp"
    android:background="@drawable/content_list_card_surface"
    android:orientation="vertical"
    android:paddingHorizontal="14dp"
    android:paddingVertical="12dp">

    <!-- Row 1: Icon + Label + Switch -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <ImageView
            android:id="@+id/IVIcon"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:layout_marginEnd="14dp"
            android:background="@drawable/content_icon_surface"
            android:padding="10dp"
            app:tint="@color/settings_icon_tint" />

        <TextView
            android:id="@+id/TVLabel"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:fontFamily="@font/inter"
            android:text="@string/gyroscope"
            android:textColor="@color/settings_text_primary"
            android:textSize="15sp"
            android:textStyle="bold" />

        <com.google.android.material.switchmaterial.SwitchMaterial
            android:id="@+id/SWToggle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:background="@android:color/transparent"
            app:thumbTint="@color/settings_accent"
            app:trackTintMode="src_in" />
    </LinearLayout>

    <!-- Row 2: Mode chips -->
    <LinearLayout
        android:id="@+id/LLModeRow"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="12dp"
            android:fontFamily="@font/inter"
            android:text="Mode"
            android:textColor="@color/settings_text_secondary"
            android:textSize="13sp" />

        <LinearLayout
            android:id="@+id/LLChips"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal" />
    </LinearLayout>

    <!-- Row 3: Activator button selector -->
    <LinearLayout
        android:id="@+id/LLActivatorRow"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="12dp"
            android:fontFamily="@font/inter"
            android:text="@string/gyro_activator_button"
            android:textColor="@color/settings_text_secondary"
            android:textSize="13sp" />

        <TextView
            android:id="@+id/TVActivatorValue"
            android:layout_width="wrap_content"
            android:layout_height="34dp"
            android:background="@drawable/content_type_nav_item_background"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?attr/selectableItemBackground"
            android:fontFamily="@font/inter"
            android:gravity="center"
            android:minWidth="64dp"
            android:paddingHorizontal="14dp"
            android:textColor="@color/content_type_nav_text"
            android:textSize="13sp"
            android:textStyle="bold" />
    </LinearLayout>

    <!-- Row 3b: Right Stick Gyro toggle -->
    <LinearLayout
        android:id="@+id/LLRightStickGyroRow"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:fontFamily="@font/inter"
            android:text="@string/enable_right_stick_gyro"
            android:textColor="@color/settings_text_secondary"
            android:textSize="13sp" />

        <TextView
            android:id="@+id/TVExperimental"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="8dp"
            android:fontFamily="@font/inter"
            android:text="(Experimental)"
            android:textColor="@color/settings_accent"
            android:textSize="11sp"
            android:textStyle="italic" />

        <com.google.android.material.switchmaterial.SwitchMaterial
            android:id="@+id/SWRightStickGyro"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@android:color/transparent"
            app:thumbTint="@color/settings_accent"
            app:trackTintMode="src_in" />
    </LinearLayout>

    <!-- Row 4: Calibrate Gyroscope expandable subcard -->
    <LinearLayout
        android:id="@+id/LLCalibrateContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:background="@drawable/content_asset_row_surface"
        android:orientation="vertical"
        android:paddingHorizontal="10dp"
        android:paddingVertical="6dp">

        <LinearLayout
            android:id="@+id/LLCalibrateHeader"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <FrameLayout
                android:id="@+id/FLChevronContainer"
                android:layout_width="30dp"
                android:layout_height="30dp"
                android:layout_marginEnd="10dp"
                android:background="@drawable/content_icon_surface">

                <ImageView
                    android:id="@+id/IVExpandChevron"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:padding="7dp"
                    android:scaleType="centerInside"
                    android:src="@drawable/ic_content_chevron"
                    app:tint="@color/settings_icon_tint" />
            </FrameLayout>

            <TextView
                android:id="@+id/TVCalibrate"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:fontFamily="@font/inter"
                android:text="@string/calibrate_gyroscope"
                android:textColor="@color/settings_text_secondary"
                android:textSize="13sp" />
        </LinearLayout>

        <!-- Expandable calibration content -->
        <LinearLayout
            android:id="@+id/LLCalibrateContent"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone">

            <!-- X Sensitivity -->
            <TextView
                android:id="@+id/TVGyroXSensitivity"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:fontFamily="@font/inter"
                android:textColor="@color/settings_text_secondary"
                android:textSize="13sp" />

            <SeekBar
                android:id="@+id/SBGyroXSensitivity"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:background="@null"
                android:max="200"
                android:progressBackgroundTint="@color/settings_outline"
                android:progressTint="@color/settings_accent"
                android:splitTrack="false"
                android:thumbTint="@color/settings_accent" />

            <!-- Y Sensitivity -->
            <TextView
                android:id="@+id/TVGyroYSensitivity"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:fontFamily="@font/inter"
                android:textColor="@color/settings_text_secondary"
                android:textSize="13sp" />

            <SeekBar
                android:id="@+id/SBGyroYSensitivity"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:background="@null"
                android:max="200"
                android:progressBackgroundTint="@color/settings_outline"
                android:progressTint="@color/settings_accent"
                android:splitTrack="false"
                android:thumbTint="@color/settings_accent" />

            <!-- Smoothing -->
            <TextView
                android:id="@+id/TVGyroSmoothing"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:fontFamily="@font/inter"
                android:textColor="@color/settings_text_secondary"
                android:textSize="13sp" />

            <SeekBar
                android:id="@+id/SBGyroSmoothing"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:background="@null"
                android:max="100"
                android:progressBackgroundTint="@color/settings_outline"
                android:progressTint="@color/settings_accent"
                android:splitTrack="false"
                android:thumbTint="@color/settings_accent" />

            <!-- Deadzone -->
            <TextView
                android:id="@+id/TVGyroDeadzone"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:fontFamily="@font/inter"
                android:textColor="@color/settings_text_secondary"
                android:textSize="13sp" />

            <SeekBar
                android:id="@+id/SBGyroDeadzone"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:background="@null"
                android:max="100"
                android:progressBackgroundTint="@color/settings_outline"
                android:progressTint="@color/settings_accent"
                android:splitTrack="false"
                android:thumbTint="@color/settings_accent" />

            <!-- Invert X -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:fontFamily="@font/inter"
                    android:text="Invert X"
                    android:textColor="@color/settings_text_secondary"
                    android:textSize="13sp" />

                <com.google.android.material.switchmaterial.SwitchMaterial
                    android:id="@+id/SWInvertGyroX"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@android:color/transparent"
                    app:thumbTint="@color/settings_accent"
                    app:trackTintMode="src_in" />
            </LinearLayout>

            <!-- Invert Y -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:fontFamily="@font/inter"
                    android:text="Invert Y"
                    android:textColor="@color/settings_text_secondary"
                    android:textSize="13sp" />

                <com.google.android.material.switchmaterial.SwitchMaterial
                    android:id="@+id/SWInvertGyroY"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@android:color/transparent"
                    app:thumbTint="@color/settings_accent"
                    app:trackTintMode="src_in" />
            </LinearLayout>

            <!-- Gyroscope stick visualization -->
            <FrameLayout
                android:id="@+id/FLStickPlaceholder"
                android:layout_width="match_parent"
                android:layout_height="160dp"
                android:layout_marginTop="12dp"
                android:background="#000000"
                android:clipChildren="true" />

            <!-- Reset button -->
            <TextView
                android:id="@+id/TVResetStick"
                android:layout_width="wrap_content"
                android:layout_height="34dp"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="10dp"
                android:layout_marginBottom="4dp"
                android:background="@drawable/content_type_nav_item_background"
                android:clickable="true"
                android:focusable="true"
                android:foreground="@drawable/rounded_ripple_accent"
                android:fontFamily="@font/inter"
                android:gravity="center"
                android:minWidth="64dp"
                android:paddingHorizontal="14dp"
                android:text="Reset Stick"
                android:textColor="@color/content_type_nav_text"
                android:textSize="13sp"
                android:textStyle="bold" />

        </LinearLayout>
    </LinearLayout>

</LinearLayout>
