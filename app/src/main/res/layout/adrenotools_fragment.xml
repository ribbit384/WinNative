<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/window_background_color_dark">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:paddingStart="16dp"
        android:paddingTop="16dp"
        android:paddingEnd="0dp"
        android:paddingBottom="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginEnd="16dp"
            android:layout_marginBottom="10dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/TVHeaderLabel"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:fontFamily="@font/inter"
                android:letterSpacing="0.02"
                android:text="@string/settings_drivers_manager_header"
                android:textColor="@color/settings_text_primary"
                android:textSize="18sp"
                android:textStyle="bold" />

            <ImageButton
                android:id="@+id/BTAddSource"
                android:layout_width="34dp"
                android:layout_height="34dp"
                android:layout_marginEnd="12dp"
                android:background="@drawable/content_icon_surface"
                android:contentDescription="Add Driver Source"
                android:padding="8dp"
                android:src="@drawable/ic_content_linked"
                app:tint="@color/settings_icon_tint" />

            <ImageButton
                android:id="@+id/BTInstallDriver"
                android:layout_width="34dp"
                android:layout_height="34dp"
                android:background="@drawable/content_icon_surface"
                android:contentDescription="@string/settings_drivers_install"
                android:padding="8dp"
                android:src="@drawable/ic_content_add"
                app:tint="@color/settings_icon_tint" />
        </LinearLayout>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/RecyclerView"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:clipToPadding="false"
            android:scrollbarThumbVertical="@drawable/nav_scrollbar_thumb"
            android:scrollbarSize="2dp"
            android:scrollbarStyle="insideInset"
            android:scrollbars="vertical"
            android:fadeScrollbars="true"
            android:scrollbarFadeDuration="320"
            android:scrollbarDefaultDelayBeforeFade="220"
            android:overScrollMode="ifContentScrolls"
            app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager" />

        <TextView
            android:id="@+id/TVEmptyText"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:fontFamily="@font/inter"
            android:gravity="center"
            android:paddingHorizontal="24dp"
            android:text="@string/common_ui_no_items_to_display"
            android:textColor="@color/settings_text_secondary"
            android:textSize="15sp"
            android:visibility="gone" />
    </LinearLayout>

</FrameLayout>