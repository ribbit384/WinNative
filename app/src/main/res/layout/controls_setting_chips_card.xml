<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="10dp"
    android:background="@drawable/content_list_card_surface"
    android:orientation="vertical"
    android:paddingHorizontal="14dp"
    android:paddingVertical="12dp">

    <!-- Header: Icon + Title -->
    <LinearLayout
        android:id="@+id/HeaderRow"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <ImageView
            android:id="@+id/IVIcon"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:layout_marginEnd="14dp"
            android:background="@drawable/content_icon_surface"
            android:padding="10dp"
            app:tint="@color/settings_icon_tint" />

        <TextView
            android:id="@+id/TVLabel"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_gravity="center_vertical"
            android:layout_weight="1"
            android:fontFamily="@font/inter"
            android:maxLines="1"
            android:textColor="@color/settings_text_primary"
            android:textSize="15sp"
            android:textStyle="bold" />
    </LinearLayout>

    <!-- Chips row -->
    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:clipToPadding="false"
        android:scrollbars="none"
        android:overScrollMode="ifContentScrolls">

        <LinearLayout
            android:id="@+id/LLChips"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal" />
    </HorizontalScrollView>

    <!-- Expandable inner card: always visible with chevron, description shown when expanded -->
    <LinearLayout
        android:id="@+id/LLDescriptionContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:background="@drawable/content_asset_row_surface"
        android:gravity="center_vertical"
        android:orientation="vertical"
        android:paddingHorizontal="10dp"
        android:paddingVertical="6dp">

        <FrameLayout
            android:id="@+id/FLChevronContainer"
            android:layout_width="30dp"
            android:layout_height="30dp"
            android:background="@drawable/content_icon_surface">

            <ImageView
                android:id="@+id/IVExpandChevron"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:padding="7dp"
                android:scaleType="centerInside"
                android:src="@drawable/ic_content_chevron"
                app:tint="@color/settings_icon_tint" />
        </FrameLayout>

        <TextView
            android:id="@+id/TVDescription"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:fontFamily="@font/inter"
            android:lineSpacingMultiplier="1.3"
            android:textColor="@color/settings_text_secondary"
            android:textSize="12sp"
            android:visibility="gone" />
    </LinearLayout>

</LinearLayout>
