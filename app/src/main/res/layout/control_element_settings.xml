<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:background="@drawable/content_popup_menu_background"
    android:scrollbars="none">

    <LinearLayout
        android:orientation="vertical"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp">

        <TextView
            style="@style/OtherSettingsSectionLabel"
            android:text="@string/input_controls_editor_type" />

        <Spinner
            style="@style/OtherSettingsSpinner"
            android:id="@+id/SType"
            android:layout_width="match_parent"
            android:layout_marginBottom="12dp"
            android:spinnerMode="dropdown" />

        <LinearLayout
            android:id="@+id/LLShape"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                style="@style/OtherSettingsSectionLabel"
                android:text="@string/input_controls_editor_shape" />

            <Spinner
                style="@style/OtherSettingsSpinner"
                android:id="@+id/SShape"
                android:layout_width="match_parent"
                android:layout_marginBottom="12dp"
                android:spinnerMode="dropdown" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="4dp"
            android:orientation="horizontal">

            <TextView
                style="@style/OtherSettingsSectionLabel"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:text="@string/input_controls_editor_scale"/>

            <TextView
                android:id="@+id/TVScale"
                style="@style/OtherSettingsSectionLabel"
                android:layout_width="wrap_content"
                android:textColor="@color/settings_accent" />
        </LinearLayout>

        <SeekBar
            android:id="@+id/SBScale"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:min="50"
            android:max="150" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="4dp"
            android:orientation="horizontal">

            <TextView
                style="@style/OtherSettingsSectionLabel"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:text="@string/input_controls_editor_opacity"/>

            <TextView
                android:id="@+id/TVOpacity"
                style="@style/OtherSettingsSectionLabel"
                android:layout_width="wrap_content"
                android:textColor="@color/settings_accent" />
        </LinearLayout>

        <SeekBar
            android:id="@+id/SBOpacity"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:min="10"
            android:max="100" />

        <LinearLayout
            android:id="@+id/LLRangeOptions"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                style="@style/OtherSettingsSectionLabel"
                android:text="@string/input_controls_editor_range" />

            <Spinner
                style="@style/OtherSettingsSpinner"
                android:id="@+id/SRange"
                android:layout_width="match_parent"
                android:layout_marginBottom="12dp"
                android:spinnerMode="dropdown" />

            <TextView
                style="@style/OtherSettingsSectionLabel"
                android:text="@string/session_display_orientation" />

            <RadioGroup
                android:id="@+id/RGOrientation"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:orientation="horizontal">

                <RadioButton
                    android:id="@+id/RBHorizontal"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/settings_text_primary"
                    android:text="@string/session_display_horizontal" />

                <RadioButton
                    android:id="@+id/RBVertical"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/settings_text_primary"
                    android:text="@string/session_display_vertical" />
            </RadioGroup>

            <TextView
                style="@style/OtherSettingsSectionLabel"
                android:text="@string/session_display_columns" />

            <Spinner
                style="@style/OtherSettingsSpinner"
                android:id="@+id/SColumns"
                android:layout_width="match_parent"
                android:layout_marginBottom="12dp"
                android:spinnerMode="dropdown" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/LLRadialMenuOptions"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                style="@style/OtherSettingsSectionLabel"
                android:text="@string/input_controls_editor_number_of_bindings" />

            <Spinner
                style="@style/OtherSettingsSpinner"
                android:id="@+id/SBindingsCount"
                android:layout_width="match_parent"
                android:layout_marginBottom="12dp"
                android:spinnerMode="dropdown" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/LLBindings"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical" />

        <LinearLayout
            android:id="@+id/LLDPadBindings"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:visibility="gone"
            android:orientation="vertical">

            <TextView
                style="@style/OtherSettingsSectionLabel"
                android:text="@string/input_controls_editor_binding_up" />

            <Spinner
                style="@style/OtherSettingsSpinner"
                android:id="@+id/SBindingUp"
                android:layout_width="match_parent"
                android:layout_marginBottom="12dp"
                android:spinnerMode="dropdown" />

            <TextView
                style="@style/OtherSettingsSectionLabel"
                android:text="@string/input_controls_editor_binding_right" />

            <Spinner
                style="@style/OtherSettingsSpinner"
                android:id="@+id/SBindingRight"
                android:layout_width="match_parent"
                android:layout_marginBottom="12dp"
                android:spinnerMode="dropdown" />

            <TextView
                style="@style/OtherSettingsSectionLabel"
                android:text="@string/input_controls_editor_binding_down" />

            <Spinner
                style="@style/OtherSettingsSpinner"
                android:id="@+id/SBindingDown"
                android:layout_width="match_parent"
                android:layout_marginBottom="12dp"
                android:spinnerMode="dropdown" />

            <TextView
                style="@style/OtherSettingsSectionLabel"
                android:text="@string/input_controls_editor_binding_left" />

            <Spinner
                style="@style/OtherSettingsSpinner"
                android:id="@+id/SBindingLeft"
                android:layout_width="match_parent"
                android:layout_marginBottom="12dp"
                android:spinnerMode="dropdown" />
        </LinearLayout>

        <CheckBox
            android:id="@+id/CBToggleSwitch"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:textColor="@color/settings_text_primary"
            android:text="@string/input_controls_editor_toggle_switch" />

        <LinearLayout
            android:id="@+id/LLCustomTextIcon"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                style="@style/OtherSettingsSectionLabel"
                android:text="@string/common_ui_custom_text" />

            <EditText
                style="@style/OtherSettingsEditText"
                android:id="@+id/ETCustomText"
                android:maxLength="8"
                android:layout_width="match_parent"
                android:layout_marginBottom="12dp"
                android:hint="@string/common_ui_none"
                android:inputType="textCapCharacters" />

            <TextView
                style="@style/OtherSettingsSectionLabel"
                android:text="@string/common_ui_icon" />

            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp">

                <LinearLayout
                    android:id="@+id/LLIconList"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal" />
            </HorizontalScrollView>
        </LinearLayout>
    </LinearLayout>
</ScrollView>
