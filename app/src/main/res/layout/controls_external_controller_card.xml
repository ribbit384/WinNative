<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="10dp"
    android:background="@drawable/content_list_card_surface"
    android:orientation="vertical"
    android:paddingHorizontal="14dp"
    android:paddingVertical="12dp">

    <!-- Row 1: Icon + Controller Name + Status + Remove Button -->
    <LinearLayout
        android:id="@+id/LLControllerHeader"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:minHeight="48dp"
        android:orientation="horizontal">

        <ImageView
            android:id="@+id/IVIcon"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:layout_marginEnd="14dp"
            android:background="@drawable/content_icon_surface"
            android:padding="10dp"
            android:src="@drawable/icon_gamepad"
            app:tint="@color/settings_icon_tint" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_gravity="center_vertical"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/TVControllerName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:fontFamily="@font/inter"
                android:maxLines="1"
                android:ellipsize="end"
                android:textColor="@color/settings_text_primary"
                android:textSize="15sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/TVBindingCount"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:fontFamily="@font/inter"
                android:maxLines="1"
                android:textColor="@color/settings_text_secondary"
                android:textSize="12sp" />
        </LinearLayout>

        <ImageButton
            android:id="@+id/BTRemove"
            android:layout_width="34dp"
            android:layout_height="34dp"
            android:layout_marginStart="8dp"
            android:background="@drawable/content_action_button_background"
            android:padding="8dp"
            android:scaleType="centerInside"
            android:src="@drawable/ic_content_menu_remove"
            android:visibility="gone"
            app:tint="@color/settings_icon_tint" />
    </LinearLayout>

    <!-- Row 2: Control Bindings expandable subcard -->
    <LinearLayout
        android:id="@+id/LLBindingsContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:background="@drawable/content_asset_row_surface"
        android:orientation="vertical"
        android:paddingHorizontal="10dp"
        android:paddingVertical="6dp">

        <LinearLayout
            android:id="@+id/LLBindingsHeader"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <FrameLayout
                android:id="@+id/FLChevronContainer"
                android:layout_width="30dp"
                android:layout_height="30dp"
                android:layout_marginEnd="10dp"
                android:background="@drawable/content_icon_surface">

                <ImageView
                    android:id="@+id/IVExpandChevron"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:padding="7dp"
                    android:scaleType="centerInside"
                    android:src="@drawable/ic_content_chevron"
                    app:tint="@color/settings_icon_tint" />
            </FrameLayout>

            <TextView
                android:id="@+id/TVBindingsLabel"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:fontFamily="@font/inter"
                android:text="@string/control_bindings"
                android:textColor="@color/settings_text_secondary"
                android:textSize="13sp" />
        </LinearLayout>

        <!-- Expandable bindings content -->
        <LinearLayout
            android:id="@+id/LLBindingsContent"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone">

            <!-- Binding list container (populated programmatically) -->
            <LinearLayout
                android:id="@+id/LLBindingsList"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:orientation="vertical" />

            <!-- Empty state / instruction text -->
            <TextView
                android:id="@+id/TVEmptyBindings"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:layout_marginBottom="8dp"
                android:fontFamily="@font/inter"
                android:gravity="center"
                android:text="@string/press_any_button_on_your_controller"
                android:textColor="@color/settings_text_secondary"
                android:textSize="13sp" />
        </LinearLayout>
    </LinearLayout>
</LinearLayout>
