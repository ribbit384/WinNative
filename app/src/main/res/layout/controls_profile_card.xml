<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="10dp"
    android:background="@drawable/content_list_card_surface"
    android:gravity="center_vertical"
    android:minHeight="72dp"
    android:orientation="horizontal"
    android:paddingHorizontal="14dp"
    android:paddingVertical="12dp">

    <ImageView
        android:id="@+id/IVIcon"
        android:layout_width="44dp"
        android:layout_height="44dp"
        android:layout_marginEnd="14dp"
        android:background="@drawable/content_icon_surface"
        android:padding="10dp"
        android:src="@drawable/ic_input_controls"
        app:tint="@color/settings_icon_tint" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_gravity="center_vertical"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/TVProfileName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:fontFamily="@font/inter"
            android:maxLines="1"
            android:ellipsize="end"
            android:textColor="@color/settings_text_primary"
            android:textSize="15sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/TVProfileSubtitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:fontFamily="@font/inter"
            android:maxLines="1"
            android:textColor="@color/settings_text_secondary"
            android:textSize="12sp" />
    </LinearLayout>

    <ImageButton
        android:id="@+id/BTOpenEditor"
        android:layout_width="34dp"
        android:layout_height="34dp"
        android:layout_marginStart="4dp"
        android:background="@drawable/content_action_button_background"
        android:padding="8dp"
        android:src="@drawable/ic_input_controls"
        app:tint="@color/settings_icon_tint"
        android:contentDescription="@string/controls_editor" />

    <ImageButton
        android:id="@+id/BTAddProfile"
        android:layout_width="34dp"
        android:layout_height="34dp"
        android:layout_marginStart="6dp"
        android:background="@drawable/content_action_button_background"
        android:padding="8dp"
        android:src="@drawable/ic_content_add"
        app:tint="@color/settings_icon_tint"
        android:contentDescription="@string/add" />

    <ImageButton
        android:id="@+id/BTEditProfile"
        android:layout_width="34dp"
        android:layout_height="34dp"
        android:layout_marginStart="6dp"
        android:background="@drawable/content_action_button_background"
        android:padding="8dp"
        android:src="@drawable/ic_controls_edit"
        app:tint="@color/settings_icon_tint"
        android:contentDescription="@string/edit" />

    <ImageButton
        android:id="@+id/BTDuplicateProfile"
        android:layout_width="34dp"
        android:layout_height="34dp"
        android:layout_marginStart="6dp"
        android:background="@drawable/content_action_button_background"
        android:padding="8dp"
        android:src="@drawable/ic_controls_duplicate"
        app:tint="@color/settings_icon_tint"
        android:contentDescription="@string/duplicate" />

    <ImageButton
        android:id="@+id/BTRemoveProfile"
        android:layout_width="34dp"
        android:layout_height="34dp"
        android:layout_marginStart="6dp"
        android:background="@drawable/content_action_button_background"
        android:padding="7dp"
        android:src="@drawable/ic_content_menu_remove"
        app:tint="@color/settings_icon_tint"
        android:contentDescription="@string/remove" />

</LinearLayout>
