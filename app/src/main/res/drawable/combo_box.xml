<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <layer-list>
            <item>
                <shape android:shape="rectangle">
                    <corners android:radius="7dp" />
                    <solid android:color="@color/settings_action_surface_pressed" />
                    <stroke
                        android:width="1dp"
                        android:color="@color/settings_input_outline_soft" />
                </shape>
            </item>
            <item
                android:drawable="@drawable/ic_dropdown_arrow"
                android:gravity="center_vertical|end"
                android:end="12dp" />
        </layer-list>
    </item>

    <item android:state_focused="true">
        <layer-list>
            <item>
                <shape android:shape="rectangle">
                    <corners android:radius="7dp" />
                    <solid android:color="@color/settings_action_surface" />
                    <stroke
                        android:width="1dp"
                        android:color="@color/settings_input_outline_soft" />
                </shape>
            </item>
            <item
                android:drawable="@drawable/ic_dropdown_arrow"
                android:gravity="center_vertical|end"
                android:end="12dp" />
        </layer-list>
    </item>

    <item>
        <layer-list>
            <item>
                <shape android:shape="rectangle">
                    <corners android:radius="7dp" />
                    <solid android:color="@color/settings_action_surface" />
                    <stroke
                        android:width="1dp"
                        android:color="@color/settings_input_outline_soft" />
                </shape>
            </item>
            <item
                android:drawable="@drawable/ic_dropdown_arrow"
                android:gravity="center_vertical|end"
                android:end="12dp" />
        </layer-list>
    </item>
</selector>
